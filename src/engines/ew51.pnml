// Sgroups
// E.91 livery
spritegroup sgroup_e91_head {
    loaded:     [sset_e91_head];
    loading:    [sset_e91_head_open];
}
spritegroup sgroup_e91_mid {
    loaded:     [sset_e91_mid];
    loading:    [sset_e91_mid_open];
}
spritegroup sgroup_e91_tail {
